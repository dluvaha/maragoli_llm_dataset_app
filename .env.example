# ═══════════════════════════════════════════════════════════════
# Maragoli LLM Dataset App — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ── Database (PostgreSQL) ────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=maragoli_llm_db
DB_USER=maragoli_user
DB_PASSWORD=your-secure-password-here
DB_HOST=localhost
DB_PORT=5432

# ── Database (SQLite — uncomment to use SQLite instead) ──────
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=
